# ─── Backend Configuration ────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tranzo

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-256-bit-secret-key-here-minimum-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-here-minimum-16-chars

# ZeroDev & Bundler
ZERODEV_PROJECT_ID=your-zerodev-project-id
ZERODEV_RPC_URL=https://rpc.zerodev.app/api/v3/<project-id>/chain/84532
BUNDLER_RPC_URL=https://rpc.zerodev.app/api/v3/<project-id>/bundler
BUNDLER_API_KEY=optional-bundler-api-key

# Email
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@tranzo.money

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Chains
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
BASE_RPC_URL=https://sepolia.base.org
DEFAULT_CHAIN_ID=84532

# Smart Contracts (deployed addresses)
DRIPPER_CONTRACT_ADDRESS=0x...
ACCOUNT_FACTORY_ADDRESS=0x...
PAYMASTER_ADDRESS=0x...
BACKEND_SIGNER_ADDRESS=0x...
CARD_SETTLEMENT_ADDRESS=0x...

# Environment
NODE_ENV=development
PORT=3000
