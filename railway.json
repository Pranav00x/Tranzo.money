{
  "$schema": "https://railway.app/json-schema/railway.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd backend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd backend && npm run start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
