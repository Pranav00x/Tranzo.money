# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tranzo

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this

# ─── Openfort ─────────────────────────────────────────
OPENFORT_API_KEY=sk_live_...
OPENFORT_POLICY_ID=pol_...
OPENFORT_CONTRACT_ID=con_...

# ─── Email (Nodemailer / Resend) ──────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_...
EMAIL_FROM=noreply@tranzo.money

# ─── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ─── Chains ───────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/...
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...
DEFAULT_CHAIN_ID=137
